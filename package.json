{
  "name": "markstay",
  "version": "0.3.0",
  "description": "Reference JavaScript implementation of the markstay spec (v1.1, parser-free core) with a stamp/lint CLI",
  "type": "module",
  "license": "MIT",
  "author": "markstaymd <markstaymd@users.noreply.github.com>",
  "homepage": "https://markstay.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markstaymd/markstay-core.git"
  },
  "bugs": {
    "url": "https://github.com/markstaymd/markstay-core/issues"
  },
  "keywords": [
    "markstay",
    "markdown",
    "block-identity",
    "content-addressed",
    "diff",
    "linter",
    "spec"
